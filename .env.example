# Environment Configuration Example
# Copy this file to .env and fill in your values

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=true

# Database (Use PostgreSQL URL for production, SQLite for development)
DATABASE_URL=sqlite:///estatecore.db
# For PostgreSQL: DATABASE_URL=postgresql://username:password@localhost:5432/estatecore

# Security Keys (Generate secure random keys for production)
SECRET_KEY=dev-secret-change-me-for-production
JWT_SECRET_KEY=dev-jwt-secret-change-me-for-production

# CORS Settings (Add your frontend domain for production)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# Email Configuration (Optional - for sending invites and notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_DEFAULT_SENDER=EstateCore <your_email@gmail.com>

# Production Deployment Notes:
# 1. Set FLASK_ENV=production for deployment
# 2. Use strong, unique SECRET_KEY and JWT_SECRET_KEY
# 3. Update ALLOWED_ORIGINS with your actual frontend domain
# 4. Use PostgreSQL DATABASE_URL for production (Render provides this)
# 5. Configure email settings if you want to send emails